# ── LUDICS v2 (Phase 2f) ───────────────────────────────────────────────────
# WS-3 (B6) scoped JWT auth for /api/v3/ludics/* routes.
# Generate with: `openssl rand -base64 48`. Mint per-caller tokens via
# `npx tsx scripts/mintMcpToken.ts --deliberation <id> --participant <id>`.
# LUDICS_LEGACY_BEARER (and the MCP_API_TOKEN bearer fallback it gated) were
# removed in the v2.5 cutover — scoped JWTs are now the only bearer path on
# /api/v3/ludics/*. MCP_API_TOKEN itself is still consumed by non-ludics
# surfaces (lib/citation/mcpAuth.ts, isonomia MCP server) and is intentionally
# left in place.
LUDICS_JWT_SIGNING_KEY=
LUDICS_JWT_ISSUER=mesh-ludics

ENABLE_FAV_BUILDER=false
ENABLE_PREDICTION_MARKETS=false
INTERNAL_JOB_TOKEN=

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_PROJECT_NAME=
PINECONE_INDEX_NAME=users

AWS_SES_REGION=
KINDLE_SENDER=
KINDLE_ADDRESS=
OPENAI_API_KEY=


# Phase 6: LLM async auto-naming of deliberations. 1|true|on to enable.
DELIBERATION_LLM_AUTO_NAMING=0
