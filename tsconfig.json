{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "typeRoots": ["./node_modules/@types", "./types"],
    "incremental": true,
    "types": ["node"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/sheaf-acl": ["packages/sheaf-acl/src/index.ts"]

    }
    
  },
  "include": [
    "next-env.d.ts",
    "shader.d.ts",
    "**/*.ts",
    "types/osc.d.ts",
    "osc.d.ts",
    "**/*.tsx",
    "app/**/*",
    ".next/types/**/*.ts",
    "scripts/**/*.ts", "lib/**/*.ts", "packages/**/*.ts"
  ],
  "exclude": ["node_modules", "__tests__/**"]
}